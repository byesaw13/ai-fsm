# App
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_fsm
POSTGRES_USER=ai_fsm
POSTGRES_PASSWORD=ai_fsm_dev_password
DATABASE_URL=postgresql://ai_fsm:ai_fsm_dev_password@localhost:5432/ai_fsm

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
# REQUIRED: Must be at least 32 characters. Generate with: openssl rand -hex 32
AUTH_SECRET=change_me_to_a_long_random_value_that_is_at_least_32_chars

# Public booking
# REQUIRED for /booking submissions. Use the account UUID that should own public intake.
BOOKING_ACCOUNT_ID=00000000-0000-0000-0000-000000000000

# AI (Anthropic) — REQUIRED for AI estimating features.
# The materials generator needs this and fails with a clear "AI not configured"
# message without it. The other AI helpers (SMS classify, scope, review, item
# suggester) silently fall back to rule-based behavior when it is unset, so a
# missing key degrades them quietly. Create a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# Worker
WORKER_POLL_MS=30000

# Email (SMTP) — required for portal magic links
# APP_URL is used in email link generation; defaults to http://localhost:3000
APP_URL=http://localhost:3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=hello@example.com
SMTP_PASS=your_smtp_password
# SMTP_FROM=Hello <hello@example.com>   # optional, defaults to SMTP_USER

# Secrets at rest (payment-provider tokens, etc.)
# REQUIRED to store Square credentials. Must decode to 32 bytes.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Square (card payments) — all Square config (token, location/application IDs,
# signature key, and the webhook URL) is managed in the app's Settings →
# Payments page and stored in the database; nothing Square-specific is required
# here. SQUARE_WEBHOOK_URL below is only an optional fallback if the webhook URL
# is left blank in Settings:
# SQUARE_WEBHOOK_URL=https://your-public-host/api/webhooks/square

# Optional storage (future phase)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
